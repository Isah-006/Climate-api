datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Entidade para Autenticação
model Usuario {
  id       Int               @id @default(autoincrement())
  email    String            @unique
  senha    String            // Aqui guardaremos a senha criptografada
  climas   ClimaPesquisado[] // Relação: Um utilizador pode ter várias pesquisas
}

// Entidades baseadas na tua ideia de projeto
model ClimaPesquisado {
  id           Int      @id @default(autoincrement())
  cidade       String
  temperatura  Float
  recomendacao String
  dataPesquisa DateTime @default(now())
  
  // Relação com o utilizador que fez a pesquisa
  usuarioId    Int
  usuario      Usuario  @relation(fields: [usuarioId], references: [id])
}