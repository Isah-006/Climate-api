datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Usuario {
  id       Int               @id @default(autoincrement())
  nome     String            @default("")
  email    String            @unique
  senha    String
  climas   ClimaPesquisado[]
}

model ClimaPesquisado {
  id           Int      @id @default(autoincrement())
  cidade       String
  temperatura  Float
  condicao     String   @default("")
  recomendacao String
  dataPesquisa DateTime @default(now())

  usuarioId    Int
  usuario      Usuario  @relation(fields: [usuarioId], references: [id])
}